#!/bin/sh
# Start bluealsa as an A2DP sink so phones can stream audio to the Pi

DAEMON=/usr/bin/bluealsa
PIDFILE=/var/run/bluealsa.pid

start() {
    printf "Starting bluealsa: "
    start-stop-daemon -S -q -b -m -p "$PIDFILE" -x "$DAEMON" -- -p a2dp-sink
    echo "OK"
}

stop() {
    printf "Stopping bluealsa: "
    start-stop-daemon -K -q -p "$PIDFILE"
    echo "OK"
}

case "$1" in
    start) start ;;
    stop)  stop  ;;
    restart) stop; sleep 1; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
