#!/bin/sh
# aria-mgr — management HTTP server (port 80)
# Handles WiFi captive portal in setup mode and OTA updates in normal mode.

DAEMON=/usr/bin/python3
SCRIPT=/opt/aria-companion/aria-mgr.py
PIDFILE=/var/run/aria-mgr.pid
LOGFILE=/var/log/aria-mgr.log

start() {
    printf "Starting aria-mgr: "
    start-stop-daemon -S -q -b -m -p "$PIDFILE" \
        -x "$DAEMON" -- "$SCRIPT" >> "$LOGFILE" 2>&1
    echo "OK"
}

stop() {
    printf "Stopping aria-mgr: "
    start-stop-daemon -K -q -p "$PIDFILE"
    echo "OK"
}

case "$1" in
    start)   start ;;
    stop)    stop  ;;
    restart) stop; sleep 1; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
