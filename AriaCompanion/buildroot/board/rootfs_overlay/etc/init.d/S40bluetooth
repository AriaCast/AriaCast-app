#!/bin/sh
# Start bluetoothd and bring up the adapter

DAEMON=/usr/libexec/bluetooth/bluetoothd
PIDFILE=/var/run/bluetoothd.pid

start() {
    printf "Starting bluetoothd: "
    start-stop-daemon -S -q -b -m -p "$PIDFILE" -x "$DAEMON" -- --noplugin=sap
    echo "OK"
}

stop() {
    printf "Stopping bluetoothd: "
    start-stop-daemon -K -q -p "$PIDFILE"
    echo "OK"
}

case "$1" in
    start) start ;;
    stop)  stop  ;;
    restart) stop; sleep 1; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
