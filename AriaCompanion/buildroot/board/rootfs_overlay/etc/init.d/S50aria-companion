#!/bin/sh
# aria-companion streaming daemon
# Captures A2DP audio via bluealsa and streams raw PCM to TCP port 7001

DAEMON=/usr/bin/aria-companion
PIDFILE=/var/run/aria-companion.pid
LOGFILE=/var/log/aria-companion.log

start() {
    printf "Starting aria-companion: "
    start-stop-daemon -S -q -b -m -p "$PIDFILE" \
        -x "$DAEMON" -- >> "$LOGFILE" 2>&1
    echo "OK"
}

stop() {
    printf "Stopping aria-companion: "
    start-stop-daemon -K -q -p "$PIDFILE"
    echo "OK"
}

case "$1" in
    start) start ;;
    stop)  stop  ;;
    restart) stop; sleep 1; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
