#!/bin/sh
# Draw the AriaCompanion status header on HDMI tty1 at boot.
# Subsequent init scripts append their own status lines.

TTY=/dev/tty1
[ -c "$TTY" ] || exit 0

printf '\033[2J\033[H'                                        > "$TTY"
printf '\033[1;34m  AriaCompanion\033[0m\n'                 >> "$TTY"
printf '\033[90m  Bluetooth Audio Bridge\033[0m\n'           >> "$TTY"
printf '\033[90m  ─────────────────────────\033[0m\n\n'     >> "$TTY"
printf '  Starting up...\n'                                  >> "$TTY"
